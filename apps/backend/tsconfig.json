{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": "./src",
    "paths": {
     "*": ["*"]
    },
    "types": ["jest", "node"]
  },
  "include": ["src", "prisma", "tests"]
}
