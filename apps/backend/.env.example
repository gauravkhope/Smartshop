# Backend Environment Variables
# Copy this file to .env and fill in actual values
# NEVER commit .env to Git - it should be in .gitignore

# ====================================
# DATABASE
# ====================================
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public

# ====================================
# SERVER & SECURITY
# ====================================
# Server port (Render will provide PORT environment variable)
PORT=5000

# JWT secret for signing tokens (use a long random string, min 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# ====================================
# EMAIL SERVICE
# ====================================
# Primary email provider (implemented): Brevo
BREVO_API_KEY=your-brevo-api-key

# Optional sender metadata used by the Brevo email service
EMAIL_FROM=your-verified-sender@yourdomain.com
EMAIL_FROM_NAME=SmartShop

# Legacy/compat: some deployment artifacts + current backend env validation
# still reference SMTP-style variables. If you keep validation as-is,
# you must provide these values even if Brevo is used for sending.
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ====================================
# FRONTEND URLs (for email links)
# ====================================
# Local development
FRONTEND_URL=http://localhost:3000

# Production (uncomment and update for production)
# FRONTEND_URL=https://your-vercel-frontend.vercel.app

# ====================================
# CORS CONFIGURATION
# ====================================
# Comma-separated list of allowed origins
# Example: CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ====================================
# NODE ENVIRONMENT
# ====================================
NODE_ENV=development

# ====================================
# OPTIONAL: Payment Gateway Credentials
# ====================================
# If using Razorpay or other payment providers
# RAZORPAY_KEY_ID=your_key_id
# RAZORPAY_KEY_SECRET=your_key_secret

# ====================================
# OPTIONAL: AWS S3 or File Storage
# ====================================
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# S3_BUCKET=your_bucket_name
